# Supabase
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Credenciais do admin (troque antes de usar em produção)
ADMIN_EMAIL="admin@blog.com"
ADMIN_PASSWORD="troque-esta-senha"

# Segredo para assinar o cookie de sessão (troque por uma string aleatória longa)
AUTH_SECRET="troque-por-um-segredo-aleatorio-bem-longo-1234567890"

# Chave gratuita do Google AI Studio — crie em https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Robô automático LOCAL (npm run dev): usa setInterval enquanto o servidor roda.
# Na Vercel (serverless) NÃO funciona — lá o robô é acionado pelo Vercel Cron
# (ver vercel.json). Deixe ROBOT_AUTO="false" no ambiente da Vercel.
ROBOT_AUTO="true"
ROBOT_INTERVAL_MINUTES="30"

# Segredo do Vercel Cron: protege /api/cron. Gere uma string aleatória longa e
# adicione a mesma nas Environment Variables da Vercel. O Cron envia este valor
# no header Authorization automaticamente.
CRON_SECRET=""
