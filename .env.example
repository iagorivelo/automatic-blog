# Banco de dados (SQLite local)
DATABASE_URL="file:./dev.db"

# Credenciais do admin (troque antes de usar em produção)
ADMIN_EMAIL="admin@blog.com"
ADMIN_PASSWORD="troque-esta-senha"

# Segredo para assinar o cookie de sessão (troque por uma string aleatória longa)
AUTH_SECRET="troque-por-um-segredo-aleatorio-bem-longo-1234567890"

# Chave gratuita do Google AI Studio — crie em https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Robô automático: procura e publica notícias sozinho enquanto o servidor roda
ROBOT_AUTO="true"
ROBOT_INTERVAL_MINUTES="30"
